<footer class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col items-center justify-center gap-6 lg:gap-10">
      <div class="flex flex-col lg:items-start items-center space-y-6 gap-9">
        <div class="flex space-x-6 sm:space-x-8">
          {
            [
              {
                href: "https://gitlab.com/ignaciohuichal/lupocustomdev",
                icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-8"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"></path> svg>',
                label: "Gitlab",
              },
              {
                href: "https://mail.google.com/mail/?view=cm&fs=1&to=ignaciohuichal@gmail.com&su=Hola%20Ignacio!",
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="2.1em" height="2.1em" viewBox="0 0 24 24"><path fill="currentColor" d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"/></svg>',
                label: "Email",
              },
            ].map((link) => (
              <a
                href={link.href}
                target="_blank"
                class="flex flex-col items-center group"
                aria-label={link.label}
              >
                <div class="text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out">
                  <div set:html={link.icon} />
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="flex flex-col items-center md:items-start space-y-6">
        <div class="grid grid-cols-1 gap-3 w-full max-w-xs">
          {
            [
              {
                desc: "Construido con",
                name: "Astro",
                icon: "/svg/astro.svg",
                alt: "Astro Logo",
              },
              {
                desc: "Diseñado con",
                name: "TailwindCSS",
                icon: "/svg/tailwindcss.svg",
                alt: "TailwindCSS Logo",
              },
              {
                desc: "Desplegado el",
                name: "Amazon Lightsail",
                icon: "/svg/aws.svg",
                alt: "Aws Logo",
              },
            ].map((tech) => (
              <div class="flex items-center space-x-3">
                <span class="text-[var(--white-icon)] text-sm">
                  {tech.desc}
                </span>
                <img
                  src={tech.icon}
                  alt={tech.alt}
                  class="h-5 w-5 object-contain filter brightness-0 invert opacity-50"
                  loading="lazy"
                />
                <span class="text-[var(--white-icon)] text-sm">
                  {tech.name}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[#ffffff10]">
      <p class="text-center text-sm text-[var(--white-icon)] space-y-2">
        <!-- If you are using this template, by MIT License you can't remove the copyright notice -->
        <span class="block sm:inline"
          >Copyright © 2025 <a href="https://github.com/Gothsec"
            >Lupo Dev</a
          >. All rights reserved.</span
        >
      </p>
    </div>
  </div>
</footer>
