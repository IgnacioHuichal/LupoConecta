    href: "#service",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
            <!-- Ventana de terminal -->
            <rect x="3" y="5" width="18" height="14" rx="1" />
